{
  "info": {
    "name": "access-manager",
    "description": "Use with api/openapi.yaml as the contract source of truth.\n\nCreate requests auto-save IDs into collection variables (domainId, userId, etc.) so you can \"Run collection\" top-to-bottom without manual copy-paste.\n\nSet baseUrl (default http://127.0.0.1:8080) and bearerToken (when API_BEARER_TOKEN is configured) before running.\n\nFor DELETE samples, dependents are removed first (permissions → resources/access-types → memberships → users/groups → domain).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8080"},
    {"key": "bearerToken", "value": ""},
    {"key": "domainId", "value": ""},
    {"key": "userId", "value": ""},
    {"key": "groupId", "value": ""},
    {"key": "resourceId", "value": ""},
    {"key": "permissionId", "value": ""},
    {"key": "accessTypeId", "value": ""}
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{bearerToken}}", "type": "string"}]
  },
  "item": [
    {
      "name": "Health",
      "request": {"method": "GET", "url": "{{baseUrl}}/health"},
      "auth": {"type": "noauth"}
    },
    {
      "name": "Create domain",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Example domain\"}"},
        "url": "{{baseUrl}}/api/v1/domains"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('domainId', json.ID);"]}}]
    },
    {"name": "List domains", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains?offset=0&limit=20&search=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}]}}},
    {"name": "Get domain", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}"}},
    {
      "name": "Patch domain",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Renamed domain\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}"
      }
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Alice\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('userId', json.ID);"]}}]
    },
    {"name": "List users", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains/{{domainId}}/users?offset=0&limit=20&search=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains","{{domainId}}","users"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}]}}},
    {"name": "Get user", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}"}},
    {
      "name": "Patch user",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Alice (updated)\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}"
      }
    },
    {
      "name": "Create group",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Admins\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('groupId', json.ID);"]}}]
    },
    {"name": "List groups", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups?offset=0&limit=20&search=&parent_group_id=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains","{{domainId}}","groups"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}, {"key": "parent_group_id", "value": "", "description": "Filter by parent group UUID"}]}}},
    {"name": "Get group", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}"}},
    {
      "name": "Patch group",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Admins (updated)\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}"
      }
    },
    {
      "name": "Set group parent",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"parent_group_id\": null}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/parent"
      }
    },
    {
      "name": "Create resource",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Doc\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('resourceId', json.ID);"]}}]
    },
    {"name": "List resources", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources?offset=0&limit=20&search=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains","{{domainId}}","resources"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}]}}},
    {"name": "Get resource", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources/{{resourceId}}"}},
    {
      "name": "Patch resource",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Doc (updated)\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources/{{resourceId}}"
      }
    },
    {
      "name": "Create access type",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read\", \"bit\": \"1\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('accessTypeId', json.ID);"]}}]
    },
    {"name": "List access types", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types?offset=0&limit=20&search=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains","{{domainId}}","access-types"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}]}}},
    {"name": "Get access type", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types/{{accessTypeId}}"}},
    {
      "name": "Patch access type",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read (updated)\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types/{{accessTypeId}}"
      }
    },
    {
      "name": "Create permission",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read doc\", \"resource_id\": \"{{resourceId}}\", \"access_mask\": \"1\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions"
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["var json = pm.response.json();", "if (json.ID) pm.collectionVariables.set('permissionId', json.ID);"]}}]
    },
    {"name": "List permissions", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions?offset=0&limit=20&search=&resource_id=", "host": ["{{baseUrl}}"], "path": ["api","v1","domains","{{domainId}}","permissions"], "query": [{"key": "offset", "value": "0"}, {"key": "limit", "value": "20"}, {"key": "search", "value": "", "description": "Case-insensitive title substring"}, {"key": "resource_id", "value": "", "description": "Filter by resource UUID"}]}}},
    {"name": "Get permission", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions/{{permissionId}}"}},
    {
      "name": "Patch permission",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read doc (updated)\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions/{{permissionId}}"
      }
    },
    {"name": "Add user to group", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/groups/{{groupId}}"}},
    {"name": "Grant user permission", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/permissions/{{permissionId}}"}},
    {"name": "Grant group permission", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/permissions/{{permissionId}}"}},
    {"name": "Authz check", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/authz/check?user_id={{userId}}&resource_id={{resourceId}}&access_bit=1"}},
    {"name": "Authz masks", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/authz/masks?user_id={{userId}}&resource_id={{resourceId}}"}},
    {"name": "Revoke group permission", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/permissions/{{permissionId}}"}},
    {"name": "Revoke user permission", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/permissions/{{permissionId}}"}},
    {"name": "Remove user from group", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/groups/{{groupId}}"}},
    {"name": "Delete permission", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions/{{permissionId}}"}},
    {"name": "Delete access type", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types/{{accessTypeId}}"}},
    {"name": "Delete resource", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources/{{resourceId}}"}},
    {"name": "Delete user", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}"}},
    {"name": "Delete group", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}"}},
    {"name": "Delete domain", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}"}}
  ]
}
