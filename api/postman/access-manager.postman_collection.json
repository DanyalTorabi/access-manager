{
  "info": {
    "name": "access-manager",
    "description": "Use with api/openapi.yaml as the contract source of truth. Set variables: baseUrl, bearerToken (when API_BEARER_TOKEN is set), domainId, userId, groupId, resourceId, permissionId after creating entities.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8080"},
    {"key": "bearerToken", "value": ""},
    {"key": "domainId", "value": ""},
    {"key": "userId", "value": ""},
    {"key": "groupId", "value": ""},
    {"key": "resourceId", "value": ""},
    {"key": "permissionId", "value": ""}
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{bearerToken}}", "type": "string"}]
  },
  "item": [
    {
      "name": "Health",
      "request": {"method": "GET", "url": "{{baseUrl}}/health"},
      "auth": {"type": "noauth"}
    },
    {"name": "List domains", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains"}},
    {
      "name": "Create domain",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Example domain\"}"},
        "url": "{{baseUrl}}/api/v1/domains"
      }
    },
    {"name": "List users", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users"}},
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Alice\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users"
      }
    },
    {"name": "Get user", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}"}},
    {"name": "List groups", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups"}},
    {
      "name": "Create group",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Admins\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups"
      }
    },
    {"name": "Get group", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}"}},
    {
      "name": "Set group parent",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"parent_group_id\": null}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/parent"
      }
    },
    {"name": "List resources", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources"}},
    {
      "name": "Create resource",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Doc\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources"
      }
    },
    {"name": "Get resource", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/resources/{{resourceId}}"}},
    {"name": "List access types", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types"}},
    {
      "name": "Create access type",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read\", \"bit\": \"1\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/access-types"
      }
    },
    {"name": "List permissions", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions"}},
    {
      "name": "Create permission",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\"title\": \"Read doc\", \"resource_id\": \"{{resourceId}}\", \"access_mask\": \"1\"}"},
        "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions"
      }
    },
    {"name": "Get permission", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/permissions/{{permissionId}}"}},
    {"name": "Add user to group", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/groups/{{groupId}}"}},
    {"name": "Remove user from group", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/groups/{{groupId}}"}},
    {"name": "Grant user permission", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/permissions/{{permissionId}}"}},
    {"name": "Revoke user permission", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/users/{{userId}}/permissions/{{permissionId}}"}},
    {"name": "Grant group permission", "request": {"method": "POST", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/permissions/{{permissionId}}"}},
    {"name": "Revoke group permission", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/groups/{{groupId}}/permissions/{{permissionId}}"}},
    {"name": "Authz check", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/authz/check?user_id={{userId}}&resource_id={{resourceId}}&access_bit=1"}},
    {"name": "Authz masks", "request": {"method": "GET", "url": "{{baseUrl}}/api/v1/domains/{{domainId}}/authz/masks?user_id={{userId}}&resource_id={{resourceId}}"}}
  ]
}
